# yfind_aiplatform 本地数据库配置
# 仅用于本地 Docker Compose；不要在这里写入生产密码。
POSTGRES_DB=yfind_aiplatform
POSTGRES_USER=yfind
POSTGRES_PASSWORD=yfind_local_password
POSTGRES_PORT=5432

# Spring Boot 运行时读取
POSTGRES_JDBC_URL=jdbc:postgresql://localhost:5432/yfind_aiplatform
POSTGRES_TEST_JDBC_URL=jdbc:postgresql://localhost:5432/yfind_aiplatform_test
DB_DRIVER=org.postgresql.Driver
